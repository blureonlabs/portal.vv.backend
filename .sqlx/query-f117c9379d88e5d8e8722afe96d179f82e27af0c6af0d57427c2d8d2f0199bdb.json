  "query": "SELECT o.id, o.profile_id, p.full_name, p.email,\n                      p.phone, o.company_name, o.notes, o.is_active, o.created_at\n               FROM owners o\n               JOIN profiles p ON p.id = o.profile_id\n               ORDER BY p.full_name\n               LIMIT $1 OFFSET $2",
