  "query": "\n            INSERT INTO settings (key, value, updated_by)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (key) DO UPDATE\n              SET value = EXCLUDED.value,\n                  updated_by = EXCLUDED.updated_by,\n                  updated_at = NOW()\n            RETURNING id, key, value, updated_by, updated_at\n            ",
