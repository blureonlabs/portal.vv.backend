{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                i.id, i.driver_id,\n                pd.full_name AS driver_name,\n                i.invoice_no,\n                i.period_start, i.period_end,\n                i.line_items_json,\n                i.total_aed,\n                i.pdf_url,\n                i.generated_by,\n                pg.full_name AS generated_by_name,\n                i.created_at\n            FROM invoices i\n            JOIN drivers d ON d.id = i.driver_id\n            JOIN profiles pd ON pd.id = d.profile_id\n            JOIN profiles pg ON pg.id = i.generated_by\n            WHERE i.id = $1\n            ",
