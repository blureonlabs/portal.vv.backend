  "query": "\n            SELECT\n                id,\n                entity_type AS \"entity_type: DocumentEntity\",\n                entity_id,\n                doc_type AS \"doc_type: DocumentType\",\n                file_url,\n                file_name,\n                expiry_date,\n                uploaded_by,\n                notes,\n                created_at\n            FROM documents\n            WHERE entity_type = $1\n              AND entity_id = $2\n            ORDER BY created_at DESC\n            ",
